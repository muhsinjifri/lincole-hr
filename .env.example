# Copy to .env and fill in. Never commit .env.

JOTFORM_API_KEY=your_jotform_api_key_here
# Form ID from the form URL: https://form.jotform.com/XXXXXXXXXXXX -> use XXXXXXXXXXXX
JOTFORM_FORM_ID=

# Optional. EU / GDPR-hosted accounts usually need:
# JOTFORM_API_BASE=https://eu-api.jotform.com/v1
JOTFORM_API_BASE=https://api.jotform.com/v1

# Optional: comma-separated numeric question IDs to show only those columns (e.g. 5,12,37).
# Leave empty to include every answered field (still useful for a quick admin view).
JOTFORM_FIELD_IDS=

# Optional: numeric question id for Department if the dashboard cannot auto-detect it by label.
JOTFORM_DEPARTMENT_FIELD_ID=

# Optional: numeric question id for a file-upload field (resume). Adds a column with View / Download links.
# Leave empty to auto-detect the file upload field (no Jotform web login needed to find the id).
JOTFORM_RESUME_FIELD_ID=

# If true (default), View/Download use this app as a proxy (server sends JOTFORM_API_KEY to Jotform).
# Set false to embed direct Jotform file URLs in the table instead.
JOTFORM_UPLOAD_PROXY=true

# Postgres (docker-compose.yml). Default matches compose service credentials.
DATABASE_URL=postgresql+asyncpg://jotform:jotform@127.0.0.1:5432/jotformdb

# Optional: require POST /webhooks/jotform?token=... to match this value.
WEBHOOK_SECRET=

# Optional: dashboard writes (same secret for notes + department editors in the UI).
# NOTES_API_SECRET is embedded in the page for Save — protect the dashboard URL (VPN / auth proxy).
# NOTES_API_SECRET=generate-a-long-random-string
#
# Notes: POST /api/submissions/{id}/notes — field must exist on the form (Form columns tab for QID).
# JOTFORM_NOTES_FIELD_ID=42
#
# Department: POST /api/submissions/{id}/department — auto-detects a field whose label contains "Department",
# or set JOTFORM_DEPARTMENT_FIELD_ID. Editor column appears when NOTES_API_SECRET is set (no extra env).
